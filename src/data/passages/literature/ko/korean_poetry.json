        "chapter": "봄은 간다, 일부",
        "bookDisplay": "김억 시집",
        "chapterDisplay": "봄은 간다, 일부"
      },
      "emotionCore": "sadness",
      "emotionExtended": [],
      "lines": [
        "봄은 간다",
        "꽃이 지고 바람이 분다",
